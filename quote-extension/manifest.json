{
  "manifest_version": 3,
  "name": "Daily Inspirational Quotes",
  "version": "1.0.0",
  "description": "Get a daily inspirational quote and share your reaction",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://inspirefeeds.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
